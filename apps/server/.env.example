# Database
DATABASE_URL="postgresql://user:password@localhost:5432/military_orbat"

# Auth
BETTER_AUTH_SECRET="change-me-to-a-random-secret-at-least-16-chars"
BETTER_AUTH_URL="http://localhost:3000"

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"

# Storage
STORAGE_PROVIDER=cloudinary
UPLOAD_FOLDER_PREFIX="military-orbat"

# Vercel Blob
BLOB_READ_WRITE_TOKEN=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AI (set whichever providers you want selectable from the editor; no fallbacks)
GOOGLE_GENERATIVE_AI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
